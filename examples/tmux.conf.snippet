# ── flashpaste tmux integration ────────────────────────────────────
# Append this to ~/.tmux.conf and `tmux source-file ~/.tmux.conf`.

# OSC 52 clipboard passthrough. With set-clipboard on, tmux's
# `copy-selection-*` commands emit an OSC 52 sequence that kitty (or any
# OSC 52-aware terminal) translates into a clipboard write through its
# OWN already-open Wayland connection — no wl-copy fork, no phantom
# dock entry. This is the primary clipboard-set path in v1.19+.
set -g set-clipboard on

# Fallback options consumed by flashpaste scripts. clipboard-set.sh is
# only called from the explicit `copy-pipe` bindings below (currently
# none — every copy keybinding uses copy-selection instead). It still
# fires for shell-script invocations that pipe to @clip directly. As of
# v1.19, clipboard-set.sh prefers the flashpasted daemon's text-staging
# IPC over forking wl-copy, so even this fallback no longer flashes the
# dock when the daemon is running.
set -g @clip  '/home/$USER/.local/bin/clipboard-set.sh'
set -g @paste '/home/$USER/.local/bin/get-clipboard-text.sh'

# Mouse on — required for the right-click Paste menu.
set -g mouse on

# Copy: drag-end / y / double-click / triple-click → OSC 52 → kitty
# writes the system clipboard via its own Wayland connection. No
# wl-copy fork, no clipboard-janitor SIGTERM, no "wl-clipboard"
# entry in the Ubuntu Dock's Open Windows list. Confirmed sub-1ms
# round-trip; tmux 3.2+ + kitty (or any OSC52-aware terminal) required.
bind -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-selection-no-clear
bind -T copy-mode    MouseDragEnd1Pane send-keys -X copy-selection-no-clear
bind -T copy-mode-vi y send-keys -X copy-selection-and-cancel
bind -n DoubleClick1Pane select-pane \; copy-mode -M \; send-keys -X select-word \; send-keys -X copy-selection-no-clear
bind -n TripleClick1Pane select-pane \; copy-mode -M \; send-keys -X select-line \; send-keys -X copy-selection-no-clear

# C-v in any normal pane → flashpaste tier-3 path. flashpaste-trigger
# is a 5-ms Rust client that pings the flashpasted daemon over a unix
# socket; if the daemon isn't running it falls back to the bash
# dispatch script. Same handler covers text paste AND image paste.
bind -n C-v run-shell -b "TMUX_PASTE_TRIGGER=ctrl-v flashpaste-trigger '#{pane_id}' 2>/dev/null || TMUX_PASTE_TRIGGER=ctrl-v /home/$USER/.local/bin/tmux-paste-dispatch.sh '#{pane_id}'"

# Middle-click paste from system clipboard.
bind -n MouseDown2Pane run-shell -b "buf=$(sh -c '#{@paste}'); if [ -n \"$buf\" ]; then printf '%s' \"$buf\" | tmux load-buffer -b mid_paste - 2>/dev/null && tmux paste-buffer -d -p -b mid_paste -t '#{pane_id}' 2>/dev/null; fi"

# Right-click pane menu with Paste item — same tier-3 trigger path.
# Note: many tmux configs override this with `MouseUp3Pane`. If you
# already have a custom right-click menu, just make sure its Paste item
# invokes `flashpaste-trigger '#{pane_id}'` with the TMUX_PASTE_TRIGGER
# env var so ~/.local/state/flashpaste-trigger.log can distinguish the
# right-click path from the C-v path during debugging.
#
# `-O` keeps the menu open until the user clicks an item, clicks
# outside the menu, or hits Escape — native GUI behaviour. v1.22
# removed it on the theory that `-O` froze TUIs like Claude Code
# until Escape; that reproduced on tmux <3.4 only, and removing `-O`
# made the menu hide as soon as the mouse moved toward an entry,
# which is worse. v1.23 restores it.
bind -n MouseDown3Pane display-menu -O -x M -y M \
  -T "#[align=centre,fg=#FFFFFF,bold] pane #{pane_index} " \
  "#[fg=#34C759]↳ Paste" p \
    "run-shell -b \"TMUX_PASTE_TRIGGER=right-click-menu flashpaste-trigger '#{pane_id}' 2>/dev/null || TMUX_PASTE_TRIGGER=right-click-menu /home/$USER/.local/bin/tmux-paste-dispatch.sh '#{pane_id}'\""

# Recursion-guard note: the C-v binding above intentionally re-invokes
# the dispatcher when kitty `send-text` injects a \026 byte. The
# dispatcher's lock file at $XDG_RUNTIME_DIR/tmux-paste-dispatch.lock
# turns the secondary invocation into a no-op within 2 seconds.
