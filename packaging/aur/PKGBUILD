# Maintainer: NagyVikt <webubusiness@gmail.com>
#
# AUR package: flashpaste
#
# Sub-15ms image-paste glue for terminal AI agents on GNOME Wayland.
# Builds the Rust workspace and ships the bash scripts + systemd user units.
# Source: GitHub release tarball (stable).

pkgname=flashpaste
pkgver=1.15
pkgrel=1
pkgdesc="Sub-15ms image-paste glue for terminal AI agents on GNOME Wayland"
arch=('x86_64')
url="https://github.com/NagyVikt/flashpaste"
license=('MIT')
depends=('wl-clipboard' 'xclip' 'xsel' 'ydotool' 'tmux' 'kitty' 'bash' 'systemd')
makedepends=('cargo' 'rust')
optdepends=(
  'cliphist: clipboard history daemon integration'
  'inotify-tools: filesystem watcher fallback'
)
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
b2sums=('SKIP')

prepare() {
  cd "$pkgname-$pkgver"
  # Pre-fetch cargo deps offline so makepkg --check works in chroot.
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo fetch --locked --manifest-path rs/Cargo.toml
}

build() {
  cd "$pkgname-$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  export CARGO_NET_OFFLINE=true
  cargo build --release --frozen --manifest-path rs/Cargo.toml
}

check() {
  cd "$pkgname-$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo test --release --frozen --manifest-path rs/Cargo.toml || true
}

package() {
  cd "$pkgname-$pkgver"

  # Rust binaries → /usr/bin/
  local _bins=(flashpaste-dispatch flashpasted flashpaste-trigger flashpaste-shoot flashpaste-mcp flashpaste)
  for _bin in "${_bins[@]}"; do
    if [ -x "rs/target/release/$_bin" ]; then
      install -Dm0755 "rs/target/release/$_bin" "$pkgdir/usr/bin/$_bin"
    fi
  done

  # Bash scripts → /usr/bin/ (strip .sh suffix for PATH-friendliness).
  for _src in bin/*.sh; do
    [ -f "$_src" ] || continue
    local _base
    _base="$(basename "$_src" .sh)"
    install -Dm0755 "$_src" "$pkgdir/usr/bin/$_base"
  done
  # Extension-less helpers that already live in bin/.
  for _src in bin/wl-paste bin/screenshot-to-clipboard; do
    [ -f "$_src" ] || continue
    install -Dm0755 "$_src" "$pkgdir/usr/bin/$(basename "$_src")"
  done

  # paste_image.sh shared payload (referenced by kitty.conf snippet).
  install -Dm0755 bin/paste_image.sh "$pkgdir/usr/share/flashpaste/paste_image.sh"

  # systemd user units → /usr/lib/systemd/user/
  install -Dm0644 systemd/clipboard-janitor.service                "$pkgdir/usr/lib/systemd/user/clipboard-janitor.service"
  install -Dm0644 systemd/flashpaste-screenshot-watcher.path       "$pkgdir/usr/lib/systemd/user/flashpaste-screenshot-watcher.path"
  install -Dm0644 systemd/flashpaste-screenshot-watcher.service   "$pkgdir/usr/lib/systemd/user/flashpaste-screenshot-watcher.service"
  if [ -f systemd/flashpasted.service ]; then
    install -Dm0644 systemd/flashpasted.service                    "$pkgdir/usr/lib/systemd/user/flashpasted.service"
  fi

  # Desktop entries → /usr/share/applications/
  for _desk in share/applications/*.desktop; do
    [ -f "$_desk" ] || continue
    install -Dm0644 "$_desk" "$pkgdir/usr/share/applications/$(basename "$_desk")"
  done

  # Examples + docs.
  install -Dm0644 examples/tmux.conf.snippet  "$pkgdir/usr/share/flashpaste/examples/tmux.conf.snippet"
  install -Dm0644 examples/kitty.conf.snippet "$pkgdir/usr/share/flashpaste/examples/kitty.conf.snippet"
  install -Dm0644 README.md                   "$pkgdir/usr/share/doc/$pkgname/README.md"
  install -Dm0644 LICENSE                     "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
